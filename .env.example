# COS-PLAY — Required API Keys
# Copy this file to .env and fill in your keys.
# Then export them: `set -a && source .env && set +a`

# OpenAI (for GPT-5.4 baselines and cold-start data generation)
OPENAI_API_KEY=sk-...

# Anthropic (for Claude baselines)
ANTHROPIC_API_KEY=sk-ant-...

# Google (for Gemini baselines)
GEMINI_API_KEY=AIza...

# OpenRouter (optional — unified API for all models; preferred for cold-start)
OPENROUTER_API_KEY=sk-or-...

# Vertex AI (Claude on Vertex — token is short-lived, refresh with `gcloud auth print-access-token`)
VERTEX_AI_TOKEN=AQ...
VERTEX_PROJECT=your-gcp-project-id
VERTEX_REGION=us-east5

# vLLM (for local Qwen3-8B inference during training and evaluation)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
