# Auto-detect text files and normalise line endings to LF in the repo.
* text=auto eol=lf

# Ensure shell scripts always use LF (required for bash).
*.sh text eol=lf

# Windows-specific files keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — do not touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.pt binary
*.bin binary
*.safetensors binary
*.ckpt binary
*.npy binary
*.npz binary
*.pkl binary
*.pickle binary
